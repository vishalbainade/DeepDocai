# Server Configuration
PORT=3000

# Neon PostgreSQL Database (Connection Pooler URL)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# SMTP Configuration (Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM="LexRay" <your_verified_sender_email>

# ─── AI Provider API Keys ────────────────────────────────────────────────────

# Google Gemini (multiple keys for rotation, comma-separated)
GEMINI_API_KEYS=key1,key2,key3
# Or single key (backward compatible)
# GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter (access GPT-4o, Claude, Llama, etc.)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# GLM / Zhipu AI
# GLM_API_KEY=your_glm_api_key_here

# NVIDIA AI Endpoints
# NVIDIA_API_KEY=your_nvidia_api_key_here

# ─── Storage ──────────────────────────────────────────────────────────────────

# Supabase Storage Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_INPUT_BUCKET=file-inputs
SUPABASE_OUTPUT_BUCKET=file-outputs

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key_here

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info  # debug | info | warn | error
